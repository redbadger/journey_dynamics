{
  "contentType": "application/vnd.gorules.decision",
  "nodes": [
    {
      "id": "input",
      "type": "inputNode",
      "position": { "x": 100, "y": 300 },
      "name": "Attribute Bag"
    },
    {
      "id": "derive-person-list",
      "type": "expressionNode",
      "position": { "x": 350, "y": 300 },
      "name": "Derive Person List",
      "content": {
        "expressions": [
          {
            "id": "e1",
            "key": "persons_list",
            "value": "persons != null ? values(persons) : []"
          }
        ],
        "passThrough": true
      }
    },
    {
      "id": "derive-passenger-counts",
      "type": "expressionNode",
      "position": { "x": 600, "y": 300 },
      "name": "Derive Passenger Counts",
      "content": {
        "expressions": [
          {
            "id": "e1",
            "key": "passenger_counts.found",
            "value": "len(persons_list)"
          },
          {
            "id": "e2",
            "key": "passenger_counts.required",
            "value": "number(search.passengers.adults ?? 0) + number(search.passengers.children ?? 0) + number(search.passengers.infants ?? 0)"
          }
        ],
        "passThrough": true
      }
    },
    {
      "id": "derive-flags",
      "type": "expressionNode",
      "position": { "x": 850, "y": 300 },
      "name": "Derive Flags",
      "content": {
        "expressions": [
          {
            "id": "e1",
            "key": "computed.hasSearch",
            "value": "search.origin != null and search.destination != null"
          },
          {
            "id": "e2",
            "key": "computed.hasOutbound",
            "value": "booking.selectedOutboundFlight != null"
          },
          {
            "id": "e3",
            "key": "computed.hasReturn",
            "value": "booking.selectedReturnFlight != null"
          },
          {
            "id": "e4",
            "key": "computed.isRoundTrip",
            "value": "search.tripType == 'round-trip'"
          },
          {
            "id": "e5",
            "key": "computed.paymentDone",
            "value": "booking.paymentStatus == 'completed'"
          },
          {
            "id": "e6",
            "key": "computed.passengersComplete",
            "value": "passenger_counts.found >= passenger_counts.required and passenger_counts.found > 0 and all(persons_list, #.passengerType != null)"
          }
        ],
        "passThrough": true
      }
    },
    {
      "id": "phase-table",
      "type": "decisionTableNode",
      "position": { "x": 1100, "y": 300 },
      "name": "Phase and Actions",
      "content": {
        "hitPolicy": "first",
        "inputs": [
          {
            "id": "i-payment",
            "field": "computed.paymentDone",
            "name": "Payment Done",
            "type": "expression"
          },
          {
            "id": "i-search",
            "field": "computed.hasSearch",
            "name": "Has Search",
            "type": "expression"
          },
          {
            "id": "i-outbound",
            "field": "computed.hasOutbound",
            "name": "Has Outbound",
            "type": "expression"
          },
          {
            "id": "i-roundtrip",
            "field": "computed.isRoundTrip",
            "name": "Round Trip",
            "type": "expression"
          },
          {
            "id": "i-return",
            "field": "computed.hasReturn",
            "name": "Has Return",
            "type": "expression"
          },
          {
            "id": "i-pax",
            "field": "computed.passengersComplete",
            "name": "Passengers Complete",
            "type": "expression"
          }
        ],
        "outputs": [
          {
            "id": "o-phase",
            "field": "phase",
            "name": "Phase",
            "type": "expression"
          },
          {
            "id": "o-actions",
            "field": "suggestedActions",
            "name": "Suggested Actions",
            "type": "expression"
          }
        ],
        "rules": [
          {
            "_id": "r1-payment-done",
            "i-payment": "true",
            "i-search": "",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "",
            "o-phase": "'booking_confirmed'",
            "o-actions": "['booking_confirmation']"
          },
          {
            "_id": "r2-no-search",
            "i-payment": "",
            "i-search": "false",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "",
            "o-phase": "'collecting_search'",
            "o-actions": "[]"
          },
          {
            "_id": "r3-no-outbound",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "false",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "",
            "o-phase": "'selecting_outbound'",
            "o-actions": "['flight_search_results']"
          },
          {
            "_id": "r4-no-return",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "true",
            "i-roundtrip": "true",
            "i-return": "false",
            "i-pax": "",
            "o-phase": "'selecting_return'",
            "o-actions": "['return_flight_selection', 'flight_search_results']"
          },
          {
            "_id": "r5-pax-incomplete",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "false",
            "o-phase": "'collecting_passengers'",
            "o-actions": "['passenger_details']"
          },
          {
            "_id": "r6-pax-complete",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "true",
            "o-phase": "'collecting_payment'",
            "o-actions": "['seat_selection', 'passenger_details']"
          }
        ]
      }
    },
    {
      "id": "output",
      "type": "outputNode",
      "position": { "x": 1350, "y": 300 },
      "name": "Result"
    }
  ],
  "edges": [
    {
      "id": "edge-input-derive-person-list",
      "sourceId": "input",
      "type": "edge",
      "targetId": "derive-person-list"
    },
    {
      "id": "edge-derive-person-list-derive-passenger-counts",
      "sourceId": "derive-person-list",
      "type": "edge",
      "targetId": "derive-passenger-counts"
    },
    {
      "id": "edge-derive-passenger-counts-derive-flags",
      "sourceId": "derive-passenger-counts",
      "type": "edge",
      "targetId": "derive-flags"
    },
    {
      "id": "edge-derive-flags-phase-table",
      "sourceId": "derive-flags",
      "type": "edge",
      "targetId": "phase-table"
    },
    {
      "id": "edge-table-output",
      "sourceId": "phase-table",
      "type": "edge",
      "targetId": "output"
    }
  ]
}
