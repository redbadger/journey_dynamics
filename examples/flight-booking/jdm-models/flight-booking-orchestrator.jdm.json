{
  "contentType": "application/vnd.gorules.decision",
  "nodes": [
    {
      "id": "input",
      "type": "inputNode",
      "position": { "x": 100, "y": 300 },
      "name": "Attribute Bag"
    },
    {
      "id": "derive",
      "type": "expressionNode",
      "position": { "x": 350, "y": 300 },
      "name": "Derive Helpers",
      "content": {
        "expressions": [
          {
            "id": "e1",
            "key": "computed",
            "value": "pv = persons != null ? values(persons) : []; pn = len(pv); pt = search != null and search.passengers != null ? number(search.passengers.total) : 0; { hasSearch: search != null and search.origin != null and search.destination != null, hasOutbound: booking != null and booking.selectedOutboundFlight != null, hasReturn: booking != null and booking.selectedReturnFlight != null, isRoundTrip: search != null and search.tripType == 'round-trip', paymentDone: booking != null and booking.paymentStatus == 'completed', passengersComplete: pn >= pt and pn > 0 and (pn > 0 ? all(pv, #.passengerType != null) : false) }"
          }
        ]
      }
    },
    {
      "id": "phase-table",
      "type": "decisionTableNode",
      "position": { "x": 650, "y": 300 },
      "name": "Phase and Actions",
      "content": {
        "hitPolicy": "first",
        "inputs": [
          {
            "id": "i-payment",
            "field": "computed.paymentDone",
            "name": "Payment Done",
            "type": "expression"
          },
          {
            "id": "i-search",
            "field": "computed.hasSearch",
            "name": "Has Search",
            "type": "expression"
          },
          {
            "id": "i-outbound",
            "field": "computed.hasOutbound",
            "name": "Has Outbound",
            "type": "expression"
          },
          {
            "id": "i-roundtrip",
            "field": "computed.isRoundTrip",
            "name": "Round Trip",
            "type": "expression"
          },
          {
            "id": "i-return",
            "field": "computed.hasReturn",
            "name": "Has Return",
            "type": "expression"
          },
          {
            "id": "i-pax",
            "field": "computed.passengersComplete",
            "name": "Passengers Complete",
            "type": "expression"
          }
        ],
        "outputs": [
          {
            "id": "o-phase",
            "field": "phase",
            "name": "Phase",
            "type": "expression"
          },
          {
            "id": "o-actions",
            "field": "suggestedActions",
            "name": "Suggested Actions",
            "type": "expression"
          }
        ],
        "rules": [
          {
            "_id": "r1-payment-done",
            "i-payment": "true",
            "i-search": "",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "",
            "o-phase": "'booking_confirmed'",
            "o-actions": "['booking_confirmation']"
          },
          {
            "_id": "r2-no-search",
            "i-payment": "",
            "i-search": "false",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "",
            "o-phase": "'collecting_search'",
            "o-actions": "[]"
          },
          {
            "_id": "r3-no-outbound",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "false",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "",
            "o-phase": "'selecting_outbound'",
            "o-actions": "['flight_search_results']"
          },
          {
            "_id": "r4-no-return",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "true",
            "i-roundtrip": "true",
            "i-return": "false",
            "i-pax": "",
            "o-phase": "'selecting_return'",
            "o-actions": "['return_flight_selection', 'flight_search_results']"
          },
          {
            "_id": "r5-pax-incomplete",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "false",
            "o-phase": "'collecting_passengers'",
            "o-actions": "['passenger_details']"
          },
          {
            "_id": "r6-pax-complete",
            "i-payment": "",
            "i-search": "true",
            "i-outbound": "",
            "i-roundtrip": "",
            "i-return": "",
            "i-pax": "true",
            "o-phase": "'collecting_payment'",
            "o-actions": "['seat_selection', 'passenger_details']"
          }
        ]
      }
    },
    {
      "id": "output",
      "type": "outputNode",
      "position": { "x": 950, "y": 300 },
      "name": "Result"
    }
