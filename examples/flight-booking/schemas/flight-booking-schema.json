{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FlightBookingSchema",
  "type": "object",
  "properties": {
    "booking": {
      "anyOf": [
        {
          "$ref": "#/$defs/BookingData"
        },
        {
          "type": "null"
        }
      ]
    },
    "persons": {
      "description": "Per-passenger details, keyed by passenger ref (e.g. `passenger_0`).\nEach entry is a crypto subject `/persons/{ref}`; the PII fields within\n(marked `x-subject`) are encrypted under that passenger's DEK.",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/PassengerDetail"
      }
    },
    "search": {
      "anyOf": [
        {
          "$ref": "#/$defs/SearchCriteria"
        },
        {
          "type": "null"
        }
      ]
    },
    "searchResults": {
      "anyOf": [
        {
          "$ref": "#/$defs/SearchResults"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "AirportCode": {
      "type": "string"
    },
    "BookingData": {
      "type": "object",
      "properties": {
        "bookingReference": {
          "type": [
            "string",
            "null"
          ]
        },
        "insurance": {
          "anyOf": [
            {
              "$ref": "#/$defs/Insurance"
            },
            {
              "type": "null"
            }
          ]
        },
        "isInternational": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "payment": {
          "anyOf": [
            {
              "$ref": "#/$defs/Payment"
            },
            {
              "type": "null"
            }
          ]
        },
        "paymentStatus": {
          "anyOf": [
            {
              "$ref": "#/$defs/PaymentStatus"
            },
            {
              "type": "null"
            }
          ]
        },
        "pricing": {
          "anyOf": [
            {
              "$ref": "#/$defs/Pricing"
            },
            {
              "type": "null"
            }
          ]
        },
        "requiresVisa": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "seatUpgradeTotal": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "selectedOutboundFlight": {
          "anyOf": [
            {
              "$ref": "#/$defs/FlightSelection"
            },
            {
              "type": "null"
            }
          ]
        },
        "selectedReturnFlight": {
          "anyOf": [
            {
              "$ref": "#/$defs/FlightSelection"
            },
            {
              "type": "null"
            }
          ]
        },
        "selectedSeats": {
          "anyOf": [
            {
              "$ref": "#/$defs/SelectedSeats"
            },
            {
              "type": "null"
            }
          ]
        },
        "termsAccepted": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "CabinClass": {
      "type": "string",
      "enum": [
        "economy",
        "premium_economy",
        "business",
        "first"
      ]
    },
    "FlightOption": {
      "type": "object",
      "properties": {
        "aircraft": {
          "type": [
            "string",
            "null"
          ]
        },
        "airline": {
          "type": "string"
        },
        "arrival": {
          "type": "string"
        },
        "available": {
          "type": "boolean"
        },
        "cabinClass": {
          "anyOf": [
            {
              "$ref": "#/$defs/CabinClass"
            },
            {
              "type": "null"
            }
          ]
        },
        "departure": {
          "type": "string"
        },
        "duration": {
          "type": [
            "string",
            "null"
          ]
        },
        "flightId": {
          "type": "string"
        },
        "flightNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "price": {
          "type": "number",
          "format": "double"
        },
        "seatsRemaining": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "stops": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "flightId",
        "airline",
        "price",
        "departure",
        "arrival",
        "available"
      ]
    },
    "FlightSelection": {
      "type": "object",
      "properties": {
        "aircraft": {
          "type": [
            "string",
            "null"
          ]
        },
        "airline": {
          "type": "string"
        },
        "arrival": {
          "type": "string"
        },
        "cabinClass": {
          "anyOf": [
            {
              "$ref": "#/$defs/CabinClass"
            },
            {
              "type": "null"
            }
          ]
        },
        "departure": {
          "type": "string"
        },
        "duration": {
          "type": [
            "string",
            "null"
          ]
        },
        "flightId": {
          "type": "string"
        },
        "flightNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "price": {
          "type": "number",
          "format": "double"
        },
        "stops": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "flightId",
        "airline",
        "price",
        "departure",
        "arrival"
      ]
    },
    "Insurance": {
      "type": "object",
      "properties": {
        "insurance_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/InsuranceType"
            },
            {
              "type": "null"
            }
          ]
        },
        "price": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "selected": {
          "type": "boolean"
        }
      },
      "required": [
        "selected"
      ]
    },
    "InsuranceType": {
      "type": "string",
      "enum": [
        "basic",
        "comprehensive",
        "premium"
      ]
    },
    "PassengerCounts": {
      "type": "object",
      "properties": {
        "adults": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "children": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "infants": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "adults",
        "children",
        "infants"
      ]
    },
    "PassengerDetail": {
      "description": "Per-passenger details. All optional — captured progressively. The PII\nfields carry `x-subject = \"/persons/*\"`, marking them secret under the\npassenger's own subject (`/persons/{ref}`); `passengerType` is plaintext (an\noperational signal the workflow reads directly).",
      "type": "object",
      "properties": {
        "dateOfBirth": {
          "type": [
            "string",
            "null"
          ],
          "format": "date",
          "x-subject": "/persons/*"
        },
        "firstName": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "x-subject": "/persons/*"
        },
        "lastName": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "x-subject": "/persons/*"
        },
        "nationality": {
          "type": [
            "string",
            "null"
          ],
          "x-subject": "/persons/*"
        },
        "passengerType": {
          "anyOf": [
            {
              "$ref": "#/$defs/PassengerType"
            },
            {
              "type": "null"
            }
          ]
        },
        "passportNumber": {
          "type": [
            "string",
            "null"
          ],
          "x-subject": "/persons/*"
        }
      }
    },
    "PassengerType": {
      "type": "string",
      "enum": [
        "adult",
        "child",
        "infant"
      ]
    },
    "Payment": {
      "type": "object",
      "properties": {
        "method": {
          "anyOf": [
            {
              "$ref": "#/$defs/PaymentMethod"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "$ref": "#/$defs/PaymentStatus"
        },
        "transaction_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "status"
      ]
    },
    "PaymentMethod": {
      "type": "string",
      "enum": [
        "credit_card",
        "debit_card",
        "paypal",
        "bank_transfer"
      ]
    },
    "PaymentStatus": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed",
        "refunded"
      ]
    },
    "Pricing": {
      "type": "object",
      "properties": {
        "basePrice": {
          "type": "number",
          "format": "double"
        },
        "currency": {
          "type": "string"
        },
        "taxes": {
          "type": "number",
          "format": "double"
        },
        "totalPrice": {
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "basePrice",
        "taxes",
        "totalPrice",
        "currency"
      ]
    },
    "SearchCriteria": {
      "type": "object",
      "properties": {
        "departureDate": {
          "type": "string"
        },
        "destination": {
          "$ref": "#/$defs/AirportCode"
        },
        "origin": {
          "$ref": "#/$defs/AirportCode"
        },
        "passengers": {
          "$ref": "#/$defs/PassengerCounts"
        },
        "returnDate": {
          "type": [
            "string",
            "null"
          ]
        },
        "tripType": {
          "$ref": "#/$defs/TripType"
        }
      },
      "required": [
        "tripType",
        "origin",
        "destination",
        "departureDate",
        "passengers"
      ]
    },
    "SearchResults": {
      "type": "object",
      "properties": {
        "outbound": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/FlightOption"
          }
        },
        "returnFlights": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/FlightOption"
          }
        },
        "totalResults": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "totalResults"
      ]
    },
    "SelectedSeats": {
      "description": "Seat assignments for outbound and (optionally) return legs.",
      "type": "object",
      "properties": {
        "outbound": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "return": {
          "description": "Renamed to avoid collision with the `return` keyword.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "TripType": {
      "type": "string",
      "enum": [
        "one-way",
        "round-trip",
        "multi-city"
      ]
    }
  }
}